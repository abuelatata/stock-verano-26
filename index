      document.getElementById("ui_pill_lines").childNodes[0].textContent = t("pill_lines")+" ";

      document.getElementById("ui_unitsLabel").childNodes[0].textContent = t("unitsLabel")+" ";
      document.getElementById("ui_totalLabel").childNodes[0].textContent = t("totalLabel")+" ";

      document.getElementById("btnClear").textContent = t("btnClear");
      document.getElementById("btnPDF").textContent = t("btnPDF");
      document.getElementById("btnEmail").textContent = t("btnEmail");
      document.getElementById("lbClose").textContent = t("lbClose");
    }

    function setActiveFlag(lang){
      document.querySelectorAll(".flagBtn").forEach(b=>{
        b.classList.toggle("active", b.dataset.lang === lang);
      });
    }

    // =============================
    // Reglas de tallas (CEREMONIA 26)
    // =============================
    const SIZES_BEBE  = ["3m","6m","9m","12m","18m","2a","3a","4a"];
    const SIZES_NINO  = ["12m","18m","2a","3a","4a","5a","6a","8a","10a","12a"]; // sin 7a y 9a
    const SIZES_UNICA = ["ÚNICA"];

    function typeFromRef(ref){
      const s = String(ref || "").trim();
      if (s.length < 2) return "";
      return s.slice(0,2);
    }
    function familyFromRef(ref){
      const s = String(ref || "").trim();
      if (s.length < 3) return "";
      return s.slice(-3);
    }

    function sizesForType(type){
      if (type === "08") return SIZES_UNICA;                  // diademas
      if (["12","13","03"].includes(type)) return SIZES_BEBE; // jesusitos + braguita niño
      if (["25","04","44"].includes(type)) return SIZES_NINO; // vestidos + pantalón niño + camisas
      return SIZES_NINO;
    }

    // =============================
    // Tarifa
    // =============================
    let productos = [];

    async function loadTarifa(){
      try{
        const res = await fetch("data/tarifa.json", {cache:"no-store"});
        if(!res.ok) throw new Error("No puedo cargar data/tarifa.json");
        const data = await res.json();
        setProductosFromJSON(data);
      }catch(err){
        console.warn(err);
        document.getElementById("err").style.display = "block";
        document.getElementById("err").textContent = "No he podido cargar la tarifa. Revisa que exista /data/tarifa.json en el repo.";
      }
    }

    function setProductosFromJSON(data){
      if(!Array.isArray(data)) throw new Error("El JSON debe ser un array: [ {ref,name,price}, ... ]");

      productos = data
        .filter(x => x && (x.ref || x.name))
        .map(x => ({
          ref: String(x.ref ?? "").trim(),
          name: String(x.name ?? "").trim(),
          price: Number(x.price ?? 0)
        }))
        .filter(x => x.ref.length > 0);

      document.getElementById("count").textContent = productos.length;
      render();
    }

    // =============================
    // Pedido (estado)
    // =============================
    const order = Object.create(null);

    function getQty(ref, size){
      return (order[ref] && order[ref][size]) ? order[ref][size] : 0;
    }
    function setQty(ref, size, qty){
      if (!order[ref]) order[ref] = Object.create(null);
      order[ref][size] = Math.max(0, Number(qty) || 0);
      if (order[ref][size] === 0) delete order[ref][size];
      if (Object.keys(order[ref]).length === 0) delete order[ref];
      refreshTotals();
      render();
    }

    function formatEUR(n){
      const v = Number(n) || 0;
      return v.toLocaleString(localeForLang(), {minimumFractionDigits:2, maximumFractionDigits:2});
    }

    function nowSpain(){
      return new Date().toLocaleString("es-ES", {
        timeZone: "Europe/Madrid",
        year:"numeric", month:"2-digit", day:"2-digit",
        hour:"2-digit", minute:"2-digit", second:"2-digit"
      });
    }

    function lineUnits(ref){
      const obj = order[ref];
      if(!obj) return 0;
      return Object.values(obj).reduce((a,b)=>a+(Number(b)||0),0);
    }

    // Regla +10%: menos de 3 unidades por modelo/referencia
    function surchargeApplies(ref){
      const u = lineUnits(ref);
      return u > 0 && u < 3;
    }

    function lineSubtotal(ref, price){
      const u = lineUnits(ref);
      const base = u * (Number(price)||0);
      return surchargeApplies(ref) ? base * 1.10 : base;
    }

    function lineSurchargeAmount(ref, price){
      const u = lineUnits(ref);
      const base = u * (Number(price)||0);
      return surchargeApplies(ref) ? base * 0.10 : 0;
    }

    // =============================
    // Datos cliente
    // =============================
    function getClientData(){
      return {
        name: document.getElementById("c_name").value.trim(),
        vat: document.getElementById("c_vat").value.trim(),
        cp: document.getElementById("c_cp").value.trim(),
        city: document.getElementById("c_city").value.trim(),
        email: document.getElementById("c_email").value.trim(),
        notes: document.getElementById("c_notes").value.trim()
      };
    }
    function validateClientData(){
      const c = getClientData();
      const missing = [];
      if(!c.name) missing.push(t("lbl_name").replace(" *",""));
      if(!c.vat) missing.push(t("lbl_vat").replace(" *",""));
      if(!c.email) missing.push(t("lbl_email").replace(" *",""));
      if(!c.cp) missing.push(t("lbl_cp").replace(" *",""));
      if(!c.city) missing.push(t("lbl_city").replace(" *",""));
      return {ok: missing.length===0, missing, c};
    }

    // =============================
    // Fotos: resolver extensión (JPG/PNG/WEBP/JPEG)
    // =============================
    function placeholderDataURL(ref){
      return "data:image/svg+xml;charset=utf-8," + encodeURIComponent(
        `<svg xmlns='http://www.w3.org/2000/svg' width='1200' height='800'>
          <rect width='100%' height='100%' fill='#ffffff'/>
          <text x='50%' y='48%' text-anchor='middle' font-family='Arial' font-size='34' fill='#5c6b6b'>${t("noPhoto")}</text>
          <text x='50%' y='56%' text-anchor='middle' font-family='Arial' font-size='30' fill='#102a2a'>${ref}</text>
        </svg>`
      );
    }

    function setImageWithFallbacks(imgEl, ref){
      const candidates = [
        `images/${ref}.jpg`,
        `images/${ref}.JPG`,
        `images/${ref}.jpeg`,
        `images/${ref}.JPEG`,
        `images/${ref}.png`,
        `images/${ref}.PNG`,
        `images/${ref}.webp`,
        `images/${ref}.WEBP`
      ];

      let i = 0;
      imgEl.src = candidates[i];

      imgEl.onerror = () => {
        i++;
        if (i < candidates.length){
          imgEl.src = candidates[i];
        } else {
          imgEl.onerror = null;
          imgEl.src = placeholderDataURL(ref);
        }
      };
    }

    // =============================
    // Render
    // =============================
    const grid = document.getElementById("grid");
    const q = document.getElementById("q");
    const linesEl = document.getElementById("lines");
    const uEl = document.getElementById("u");
    const tEl = document.getElementById("t");
    const surchargeNote = document.getElementById("surchargeNote");

    function render(){
      const term = (q.value || "").trim().toLowerCase();

      const filtered = productos.filter(p=>{
        if(!term) return true;
        return (p.ref || "").toLowerCase().includes(term) || (p.name || "").toLowerCase().includes(term);
      });

      grid.innerHTML = "";
      filtered.forEach(p=>{
        const type = typeFromRef(p.ref);
        const fam  = familyFromRef(p.ref);
        const sizes = sizesForType(type);

        const u = lineUnits(p.ref);
        const sub = lineSubtotal(p.ref, p.price);
        const sur = lineSurchargeAmount(p.ref, p.price);

        const card = document.createElement("div");
        card.className = "card";

        const imgWrap = document.createElement("div");
        imgWrap.className = "imgWrap";

        const img = document.createElement("img");
        img.alt = p.ref;
        img.loading = "lazy";
        setImageWithFallbacks(img, p.ref);

        img.addEventListener("click", ()=> openLightbox(p.ref));

        const badge = document.createElement("div");
        badge.className = "imgBadge";
        badge.textContent = p.ref;

        imgWrap.appendChild(img);
        imgWrap.appendChild(badge);

        const body = document.createElement("div");
        body.className = "body";

        const titleRow = document.createElement("div");
        titleRow.className = "titleRow";

        const left = document.createElement("div");
        left.innerHTML = `<div class="ref">${p.ref}</div><div class="name">${escapeHTML(p.name || "")}</div>`;

        const price = document.createElement("div");
        price.className = "price";
        price.textContent = `${formatEUR(p.price)} €`;

        titleRow.appendChild(left);
        titleRow.appendChild(price);

        const kv = document.createElement("div");
        kv.className = "kv";
        kv.innerHTML = `
          <div>${t("type")}: <b>${escapeHTML(type)}</b></div>
          <div>${t("family")}: <b>${escapeHTML(fam)}</b></div>
          <div>${t("sizes")}: <b>${escapeHTML(sizesText(sizes))}</b></div>
          <div>${t("units")}: <b>${u}</b></div>
        `;

        const sizesBox = document.createElement("div");
        sizesBox.className = "sizes";

        const sizesHeader = document.createElement("div");
        sizesHeader.className = "sizesHeader";
        sizesHeader.innerHTML = `
          <span>${t("sizes")}</span>
          ${sur>0 ? `<span class="surchargeTag">${t("surcharge")}</span>` : `<span></span>`}
        `;

        const sizesGrid = document.createElement("div");
        sizesGrid.className = "sizesGrid";

        sizes.forEach(sz=>{
          const line = document.createElement("div");
          line.className = "sizeLine";

          const tag = document.createElement("div");
          tag.className = "sizeTag";
          tag.textContent = sz.toUpperCase();

          const step = document.createElement("div");
          step.className = "stepper";

          const minus = document.createElement("div");
          minus.className = "btn";
          minus.textContent = "−";
          minus.addEventListener("click", ()=>{
            setQty(p.ref, sz, getQty(p.ref, sz)-1);
          });

          const input = document.createElement("input");
          input.className = "qty";
          input.type = "number";
          input.min = "0";
          input.inputMode = "numeric";
          input.value = String(getQty(p.ref, sz));
          input.addEventListener("change", ()=>{
            setQty(p.ref, sz, input.value);
          });

          const plus = document.createElement("div");
          plus.className = "btn";
          plus.textContent = "+";
          plus.addEventListener("click", ()=>{
            setQty(p.ref, sz, getQty(p.ref, sz)+1);
          });

          step.appendChild(minus);
          step.appendChild(input);
          step.appendChild(plus);

          line.appendChild(tag);
          line.appendChild(step);
          sizesGrid.appendChild(line);
        });

        const lineTotal = document.createElement("div");
        lineTotal.className = "lineTotal";
        lineTotal.innerHTML = `
          <span>${t("lineSubtotal")}${sur>0 ? ` (+10%)` : ""}</span>
          <strong>${formatEUR(sub)} €</strong>
        `;

        sizesBox.appendChild(sizesHeader);
        sizesBox.appendChild(sizesGrid);
        sizesBox.appendChild(lineTotal);

        body.appendChild(titleRow);
        body.appendChild(kv);
        body.appendChild(sizesBox);

        card.appendChild(imgWrap);
        card.appendChild(body);

        grid.appendChild(card);
      });

      refreshTotals();
    }

    function sizesText(arr){
      if(arr.length === 1) return arr[0];
      return `${arr[0]}–${arr[arr.length-1]}`.toUpperCase();
    }

    function escapeHTML(s){
      return String(s||"").replace(/[&<>"']/g, (c)=>({
        "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"
      }[c]));
    }

    function refreshTotals(){
      let totalUnits = 0;
      let totalEUR = 0;
      let linesWithQty = 0;
      let totalSurcharge = 0;

      Object.keys(order).forEach(ref=>{
        const prod = productos.find(p=>p.ref === ref);
        const price = prod ? prod.price : 0;

        const u = lineUnits(ref);
        if(u>0) linesWithQty++;
        totalUnits += u;

        totalEUR += lineSubtotal(ref, price);
        totalSurcharge += lineSurchargeAmount(ref, price);
      });

      linesEl.textContent = linesWithQty;
      uEl.textContent = totalUnits;
      tEl.textContent = formatEUR(totalEUR);

      if(totalSurcharge > 0){
        surchargeNote.style.display = "block";
        surchargeNote.textContent = `${t("surchargeInfo")} (Suplemento total: ${formatEUR(totalSurcharge)} €)`;
      }else{
        surchargeNote.style.display = "none";
        surchargeNote.textContent = "";
      }
    }

    // =============================
    // Lightbox
    // =============================
    const lb = document.getElementById("lb");
    const lbImg = document.getElementById("lbImg");
    const lbTitle = document.getElementById("lbTitle");
    document.getElementById("lbClose").addEventListener("click", closeLightbox);
    lb.addEventListener("click", (e)=>{ if(e.target === lb) closeLightbox(); });

    function openLightbox(ref){
      lbTitle.textContent = ref;
      setImageWithFallbacks(lbImg, ref);
      lb.style.display = "flex";
    }
    function closeLightbox(){
      lb.style.display = "none";
      lbImg.src = "";
    }

    // =============================
    // Email
    // =============================
    function buildOrderLines(){
      const lines = [];
      Object.keys(order).forEach(ref=>{
        const prod = productos.find(p=>p.ref === ref);
        const name = prod ? prod.name : "";
        const price = prod ? prod.price : 0;

        const type = typeFromRef(ref);
        const fam = familyFromRef(ref);
        const sizes = sizesForType(type);

        const items = [];
        sizes.forEach(sz=>{
          const q = getQty(ref, sz);
          if(q>0) items.push(`${sz.toUpperCase()}: ${q}`);
        });
        if(items.length===0) return;

        const u = lineUnits(ref);
        const sub = lineSubtotal(ref, price);
        const sur = surchargeApplies(ref);

        lines.push({
          ref, name, price,
          type, fam,
          sizesText: items.join(" · "),
          units: u,
          subtotal: sub,
          surcharge: sur
        });
      });

      lines.sort((a,b)=> (a.ref>b.ref?1:-1));
      return lines;
    }

    function sendOrderEmail(){
      const v = validateClientData();
      const errEl = document.getElementById("err");
      if(!v.ok){
        errEl.style.display="block";
        errEl.textContent = `${t("missingData")} ${v.missing.join(", ")}`;
        return;
      }
      const lines = buildOrderLines();
      if(lines.length===0){
        errEl.style.display="block";
        errEl.textContent = t("noQty");
        return;
      }
      errEl.style.display="none";

      let totalUnits=0, totalEUR=0, totalSurcharge=0;
      lines.forEach(l=>{
        totalUnits += l.units;
        totalEUR += l.subtotal;
        const base = l.units * l.price;
        if(l.surcharge) totalSurcharge += base*0.10;
      });

      const subject = `${t("orderSubjectPrefix")} · ${v.c.name} · ${nowSpain().slice(0,10)}`;
      const body = [
        `${t("appGenerated")}`,
        `${t("dateTime")}: ${nowSpain()}`,
        "",
        `==============================`,
        `${t("clientDataBlock")}`,
        `==============================`,
        `Nombre: ${v.c.name}`,
        `CIF/NIF: ${v.c.vat}`,
        `Email: ${v.c.email}`,
        `CP: ${v.c.cp}`,
        `Localidad: ${v.c.city}`,
        v.c.notes ? `${t("obs")}: ${v.c.notes}` : "",
        "",
        `==============================`,
        `${t("orderDetails")}`,
        `==============================`,
        ...lines.map(l=>{
          const surTxt = l.surcharge ? ` · ${t("surcharge")}` : "";
          return `• ${l.ref} · ${l.name}\n  ${t("price")}: ${formatEUR(l.price)} €\n  ${l.sizesText}\n  ${t("units")}: ${l.units} · ${t("subtotal")}: ${formatEUR(l.subtotal)} €${surTxt}\n`;
        }),
        "",
        `${t("totalUnits")}: ${totalUnits}`,
        `${t("totalEUR")}: ${formatEUR(totalEUR)} €`,
        totalSurcharge>0 ? `${t("surcharge")}: ${formatEUR(totalSurcharge)} €` : "",
        "",
        `${t("thanks")}.`,
        `${t("confirm")}.`
      ].filter(Boolean).join("\n");

      const to = "info@abuelatata.com";
      const mailto = `mailto:${encodeURIComponent(to)}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailto;
    }

    // =============================
    // PDF
    // =============================
    async function exportPDFWithImages(){
      const v = validateClientData();
      const errEl = document.getElementById("err");
      if(!v.ok){
        errEl.style.display="block";
        errEl.textContent = `${t("missingData")} ${v.missing.join(", ")}`;
        return;
      }
      const lines = buildOrderLines();
      if(lines.length===0){
        errEl.style.display="block";
        errEl.textContent = t("noQty");
        return;
      }
      errEl.style.display="none";

      const { jsPDF } = window.jspdf;
      const doc = new jsPDF({unit:"mm", format:"a4"});

      const pageW = doc.internal.pageSize.getWidth();
      const pageH = doc.internal.pageSize.getHeight();
      const margin = 12;

      let y = 14;

      doc.setFont("helvetica","bold");
      doc.setFontSize(14);
      doc.text(t("pdfTitle"), margin, y);
      y += 8;

      doc.setFont("helvetica","normal");
      doc.setFontSize(10);
      doc.text(`${t("dateTime")}: ${nowSpain()}`, margin, y); y += 6;

      doc.setFont("helvetica","bold"); doc.text(t("clientDataBlock"), margin, y); y += 5;
      doc.setFont("helvetica","normal");
      doc.text(`Nombre: ${v.c.name}`, margin, y); y += 5;
      doc.text(`CIF/NIF: ${v.c.vat}`, margin, y); y += 5;
      doc.text(`Email: ${v.c.email}`, margin, y); y += 5;
      doc.text(`CP: ${v.c.cp} · ${v.c.city}`, margin, y); y += 6;
      if(v.c.notes){
        const noteLines = doc.splitTextToSize(`${t("obs")}: ${v.c.notes}`, pageW - margin*2);
        doc.text(noteLines, margin, y);
        y += noteLines.length*5 + 2;
      }

      doc.setFont("helvetica","bold");
      doc.text(t("orderDetails"), margin, y); y += 6;

      let totalUnits=0, totalEUR=0, totalSurcharge=0;
      lines.forEach(l=>{
        totalUnits += l.units;
        totalEUR += l.subtotal;
        const base = l.units * l.price;
        if(l.surcharge) totalSurcharge += base*0.10;
      });

      const rowH = 30;
      for(const l of lines){
        if(y + rowH + 30 > pageH){
          doc.addPage();
          y = 14;
        }

        doc.setDrawColor(220);
        doc.roundedRect(margin, y, pageW - margin*2, rowH, 3, 3);

        doc.setFont("helvetica","bold"); doc.setFontSize(11);
        doc.text(`${l.ref} · ${l.name}`, margin+3, y+8);

        doc.setFont("helvetica","normal"); doc.setFontSize(10);
        doc.text(`${t("price")}: ${formatEUR(l.price)} €`, margin+3, y+14);

        const surTxt = l.surcharge ? ` · ${t("surcharge")}` : "";
        const sizesLines = doc.splitTextToSize(l.sizesText, pageW - margin*2 - 6);
        doc.text(sizesLines.slice(0,2), margin+3, y+19);

        doc.setFont("helvetica","bold"); doc.setFontSize(10);
        const rightText = `${l.units} ${t("units")} · ${formatEUR(l.subtotal)} €${surTxt}`;
        doc.text(rightText, pageW - margin - doc.getTextWidth(rightText), y+24);

        y += rowH + 6;
      }

      if(y + 26 > pageH){
        doc.addPage();
        y = 14;
      }
      doc.setFont("helvetica","bold"); doc.setFontSize(12);
      doc.text(`${t("totalUnits")}: ${totalUnits}`, margin, y); y += 6;
      doc.text(`${t("totalEUR")}: ${formatEUR(totalEUR)} €`, margin, y); y += 6;
      if(totalSurcharge>0){
        doc.setFontSize(10);
        doc.text(`${t("surcharge")}: ${formatEUR(totalSurcharge)} €`, margin, y); y += 6;
      }

      const stamp = new Date().toISOString().slice(0,10);
      doc.save(`Repeticion_AbuelaTata_Ceremonia26_${v.c.name.replace(/\s+/g,"_")}_${stamp}.pdf`);
    }

    // =============================
    // Botones
    // =============================
    document.getElementById("btnEmail").addEventListener("click", sendOrderEmail);
    document.getElementById("btnPDF").addEventListener("click", exportPDFWithImages);

    document.getElementById("btnClear").addEventListener("click", () => {
      for (const k of Object.keys(order)) delete order[k];
      render();
